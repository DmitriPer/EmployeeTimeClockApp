# Server
NODE_ENV=development
PORT=3000

# Database (Railway MySQL — use public TCP proxy host/port for local dev)
DB_HOST=
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=

# JWT — generate two separate long random strings (e.g. openssl rand -hex 64)
JWT_SECRET=
JWT_REFRESH_SECRET=

# CORS — where the client runs
CLIENT_ORIGIN=http://localhost:5173
